# ============================================================
# FREE SETUP ONLY — copy to .env
# Primary: Google Gemini free key → https://aistudio.google.com/apikey
# Backup:  Groq free key         → https://console.groq.com
# ============================================================

# REQUIRED (free): Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL free backup
GROQ_API_KEY=

# Model (free defaults)
# google_genai/gemini-2.0-flash   ← recommended free
# google_genai/gemini-1.5-flash
# groq/llama-3.3-70b-versatile
LLM_MODEL=google_genai/gemini-2.0-flash

# Always use open-source ScrapeGraphAI library (no paid cloud API)
# open_source = free self-hosted scrapegraphai + Playwright
# demo        = no live scrape; uses built-in sample leads (zero keys needed to explore UI)
SCRAPER_MODE=open_source

# Optional: only if you later want managed ScrapeGraph cloud (NOT required)
SCRAPEGRAPH_API_KEY=

# Dashboard
DASHBOARD_PASSWORD=change-me-now

# Your agency (used in experience proposals + outreach)
AGENCY_NAME=Your Web Agency
AGENCY_WEBSITE=https://your-agency.com
AGENCY_EMAIL=hello@your-agency.com
AGENCY_WHATSAPP=+91XXXXXXXXXX
AGENCY_TAGLINE=Digital experiences for independent shops

# --- Free Google Sheets CRM (permanent lead storage) ---
# Sheet ID from: https://docs.google.com/spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEET_ID=
GOOGLE_SHEET_WORKSHEET=Leads
SHEETS_AUTO_SYNC=true
# Paste full service-account JSON as one line, OR path to file:
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=
